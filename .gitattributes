* text=auto

# Keep line endings stable across Windows/Linux.
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary asset types — tell git not to run text diff/whitespace checks on these.
*.pdf binary
*.docx binary
*.xlsx binary
*.pptx binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.zip binary
*.gz binary
