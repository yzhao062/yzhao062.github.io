# X / Twitter API credentials (OAuth 1.0a User Context)
# Get these from https://console.x.com  -> Apps -> Keys and tokens
# Copy this file to .env and fill in real values. .env is gitignored.

X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# LinkedIn API credentials (OAuth 2.0 3-legged)
# Get Client ID + Secret from https://developer.linkedin.com -> your app -> Auth.
# Leave ACCESS_TOKEN / REFRESH_TOKEN / TOKEN_EXPIRES_AT / USER_URN empty;
# scripts/post_to_linkedin.py --auth writes them back automatically.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_TOKEN_EXPIRES_AT=
LINKEDIN_USER_URN=
